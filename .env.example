# Copy this to .env and fill in your keys
# NEVER commit .env to git!

# Existing
POLYGON_API_KEY=your_polygon_key_here
ALPHAVANTAGE_API_KEY=your_av_key_here
XAI_API_KEY=your_xai_key_here  # optional

# New for AI Trading Bot (Binance Testnet for paper trading)
# Get testnet keys: https://testnet.binance.vision/
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_testnet_secret_here

# For live (DANGER - use at own risk, small amounts):
# BINANCE_API_KEY=...
# BINANCE_SECRET=...

# Bot defaults
BOT_SYMBOL=BTC/USDT
BOT_PROFIT_TARGET=0.015  # 1.5%
BOT_STAKE_PCT=0.1  # 10%

# 🚨 WARNING: Trading bots can lose all your money. Simulation/paper only recommended. No doubling guarantee.